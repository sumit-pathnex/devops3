## terraform dynamodb

resources "aws_dynamo_db" "sumit" {
  name            = "sumit_db_table"
  biling_mode     = "pay_per_request"
  hash_key        = "id"

  attributes {
    name = "id"
    type = "s"
  }


  tags = {
    name = "sumit" 
  }
}



## kubernetes stateful set

apiVersion: apps/v1
kind: statefulset
metadata:
  name: sumit
spec:
  sevicename: "sumit"
  replicas: 2
  selectors:
    matchlabels:
      app: sumit-db
    spec:
      containers:
        - name: db
	  image: mysql
	  env:
	    - name: mysql
	      value: "sumit"





# artifacts promotion


pipeline {
    agent any
    environment {
        institute_name = "sumit"
    }
    stages {
        stage('build') {
