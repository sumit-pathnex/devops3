## kubernetes 

apiVersion: apps/v1
kind: deployment
metadata: 
  name: pathnex
spec:
  replicas 3
  stategy:
    type: rollout
    rillingupdate:
      maxsurge: 2
      maxunavailable: 1
    selector:
      matchLabels: 
        app: rollout
      template:
        metadata:
	  labels:
	    app: rollout
	  spec:
	    containers: 
	      - name: app
	        image: ngoinx

