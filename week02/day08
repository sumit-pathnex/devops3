ansible install packages using variable

---
- name: install packages for pathnex
  host: all
  become: yes

  vars:
    sumit_packages:
      - tree
      - unzip
      - vim



  tasks:
    - name: install required packages
      yum: 
        name: "{{sumit_package}}"
	state: present



