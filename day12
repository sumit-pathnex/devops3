## kubernetes rolling update strategy

apiVersion: apps/v1
kind: deployment
metadata:
  name: sumit
spec:
  replicas: 3
  strategy: rollingupdate
    maxsurge: 1
    maxvunavailable: 1
selector:
  matchlabels:
    app: roll
  template:
    metadata:
      labels:
        app: roll
spec:
  containers:
    - name: web
      image: nginx







## jenkins pipeline multi branch

pipeline {
    agent any 
    environment {
        institute_name = "sumit"
    }
    stages {
        stage(checkout) {
	    steps {
	        checkout scm
	    }
	}
	stage('build') {
	    steps {
	        sh mvn clean compile
	    }
	}
    }
}



