## ansible modified existing line

---
- name: update ssh for sumit
  hosts: all
  become: yes

  tasks:
    - name: disable root login
      linefile:
        path: /etc/ssh/sshd_config
        regexp: "permit to root login"
        line: "permit to root login0"

