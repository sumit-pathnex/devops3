stages:
  - unit
  - integration

variables:
  institute_name: "sumit"
  team: "dev"
  env: "dev"

unit test:
  stage: unit
  image: maven:3.8.1-jdk-17
  script:
    - mvn test
    - echo "unit test completed"

    integration-test:
  stage: integration
  image: maven:3.8.1-jdk-17
