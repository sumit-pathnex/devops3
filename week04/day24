## ansible template

---
- name: deploy
  hosts: all
  become:

  tasks:
    - name: create config
      template:
        src:
	dest: /etc/pathnex.com



## terraform alb

resource "aws_ib_listner" "sumit" {
  load_balancer_arn = aws.lb
    port = "80"
    protocol = "http"

    defaut_action {
      type = "flexible-responce" 
      fixed_responce {
        content_type = text/plain"
	message_body = "sumit"
      }
   }
}


## kubernetes - pv + pvc

apiVersion: v1
kind: persistencevolume
metadata:
  name: sumit
spec:
  capacity:
    storage:  1Gi
  accessModes:
    - readwriteonce
  hostpath:
    path: /data/pathnex

---
apiVersion: v1
kind: pvc
metadata:
  name: "sumit"
spec:
  accessModes:
    - readWriteonce
  resources:
    storage:  500mi

