    agent any
    parameters {
        string(name: 'ENVIRONMENT', defaultValue: 'dev', description: 'Deployment environment')
    }
    environment {
        INSTITUTE_NAME = sumit
    }
    stages {
        stage('checkout') {
	    steps {
	        git url:
	    }
	}
	stage('deploy') {
