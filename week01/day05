## ansible handlers to restarate nginx

--- 
- name: manage nginx
  hosts: all
  become: yes

  tasks:
    - name: update: nginx
      copy:
        src: index.html
	dest: 
	notify: restarte nginx


handlers: 
  - name: restart nginx
  state: started


## terraform ec2 instance c6i.xlarge

resource "aws-instance0" "sumit" {
  ami
  instance_type = "c6i.xlarge"

  user_data = <<EQF
#!/bin/bash
yum install -y httpd
systmctl start httpd
EQF

  tags = {
    name = "sumit"
  }
}

## kubernetes resource limit - 

apiVersion: v1
kind: pod
metadata:
  name: sumit
spec:
  containers:
    - name: app
      image: nginx
      resources:
        limits: 
	  memory: "256MI"
	  cpu: 500



