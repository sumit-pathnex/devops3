## jenkins pipeline parallel build and test

pipeline  {
    agent any
    stages {
        stage(parallel tasks) {
	    steps {
	        sh 'mvn test'
	    }
	}
    }
}





## git labci parallel build


stages:
  - build-test

maven-build:
  stege: build-test
  image: maven:3.8.1-jdk-17
  script:
    - git clone
    - cd sample-java-app
    - mvn clean compile
  parallel: 1


maven-test:
  stage: build-test
  image: maven:3.8.2-jdk-17
  script:
    - cd sample-java-app
    - mvn test
  parallel: 1

