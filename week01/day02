## kubernetes deployment with 2 replicas

api
version: app/v1
kind: deployment
metadata:
  name: sumit
spc:
  replicas: 2
  selectors:
    matchlabels:
      app: pathnex-app
  template:
    metadata:
      labels:
        app: pathnex-app
    spec:
      containers:
        - name: app
	  image: nginx
	  ports:
	    - containerport: 80





