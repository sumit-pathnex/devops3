## ansible install and enable nginx

---
- name: intall nginx and start nginx on su
  hosts: all
  become: yes

  tasks:
    - name: install nginx
      yum:
        name: nginx
	state: present
    
    - name: enable nginx
      sevice:
        name:nginx
	state: started
	enables: yes




